# macOS
.DS_Store
.AppleDouble
.LSOverride

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Temporary files
*.tmp
*.swp
*.swo
*.swn

# Editor directories and files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace

# Frontend (HelixMind-Frontend - Next.js)
HelixMind-Frontend/node_modules/
HelixMind-Frontend/.next/
HelixMind-Frontend/out/
HelixMind-Frontend/.env*.local
HelixMind-Frontend/*.tsbuildinfo
HelixMind-Frontend/next-env.d.ts
HelixMind-Frontend/.env

# Backend (HelixMind-backend - Python)
HelixMind-backend/__pycache__/
HelixMind-backend/*.pyc
HelixMind-backend/*.pyo
HelixMind-backend/*.pyd
HelixMind-backend/.venv/
HelixMind-backend/venv/
HelixMind-backend/env/
HelixMind-backend/*.env
HelixMind-backend/.env